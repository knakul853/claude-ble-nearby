#!/bin/bash
# Bootstrap native dependencies on first run, then show status.

PLUGIN_DIR="$(cd "$(dirname "$0")/.." && pwd)"

if [ ! -d "$PLUGIN_DIR/node_modules" ]; then
  npm install --production --prefix "$PLUGIN_DIR" 2>&1
fi

echo '{"additionalContext": "BLE Nearby plugin active. Use /nearby to see who is around, or ask to chat with a nearby dev."}'
